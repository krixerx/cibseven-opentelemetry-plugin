<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             targetNamespace="http://cibseven.org/examples"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">

  <process id="testProcess" name="Test Process" isExecutable="true"
           camunda:historyTimeToLive="P180D">

    <startEvent id="startEvent" name="Start"/>

    <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="serviceTask1"/>

    <serviceTask id="serviceTask1" name="Automated Task"
                 camunda:class="org.cibseven.community.otel.integration.TestDelegate"/>

    <sequenceFlow id="flow2" sourceRef="serviceTask1" targetRef="endEvent"/>

    <endEvent id="endEvent" name="End"/>

  </process>

</definitions>
